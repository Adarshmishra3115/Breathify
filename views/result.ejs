<%- include("partials/header") %>
<%- include("partials/navbar2") %>

<style>
.container {
    max-width: 600px;
    margin: auto;
    text-align: center;
    padding: 60px 20px;
}

.card {
    background: white;
    padding: 30px;
    border-radius: 15px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.1);
}

.score {
    font-size: 2.5rem;
    margin: 20px 0;
}

.result {
    font-size: 1.5rem;
    margin-bottom: 20px;
}

.btn {
    display: inline-block;
    padding: 12px 25px;
    margin: 10px;
    border-radius: 25px;
    text-decoration: none;
    font-weight: bold;
}

.retry {
    background: #3498db;
    color: white;
}

.home {
    background: #2ecc71;
    color: white;
}

.suggestion {
    margin-top: 20px;
    font-size: 1rem;
    color: #555;
}
</style>

<div class="container">
    <div class="card">

        <h1>Your Mental Health Score 🧠</h1>

        <div class="score">
            <%= Math.round((score/45)*100) %> % STRESS
        </div>

        <div class="result">
            <%= result %>
        </div>

        <!-- Dynamic Suggestions -->
        <div class="suggestion">
            <% if (score <= 15) { %>
                <p>You're doing great! Keep maintaining a healthy lifestyle and stay positive 🌱</p>
            <% } else if (score <= 30) { %>
                <p>You're experiencing some stress. Try relaxation techniques like meditation or talking to someone 💬</p>
            <% } else { %>
                <p>High stress detected. Consider seeking professional help or using our chatbot support 🤖</p>
            <% } %>
        </div>

        <a href="/box/quiz" class="btn retry">Retake Quiz</a>
        <a href="/" class="btn home">Go Home</a>

    </div>
</div>

<%- include("partials/footer") %>