<%- include("partials/header") %>
<%- include("partials/navbar2") %>

<style>
body {
    margin: 0;
    font-family: 'Poppins', sans-serif;
    background: linear-gradient(135deg, #4facfe, #00c6ff);
    transition: 0.3s;
}

body.dark {
    background: #121212;
}

/* CONTAINER */
.container {
    max-width: 700px;
    margin: auto;
    margin-top: 60px;
    background: white;
    padding: 40px;
    border-radius: 20px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.15);
    text-align: center;
    transition: 0.3s;
}

body.dark .container {
    background: #1e1e1e;
    color: white;
}

/* TITLE */
h1 {
    margin-bottom: 10px;
}

/* PROGRESS */
.progress {
    width: 100%;
    height: 10px;
    background: #eee;
    border-radius: 10px;
    margin-bottom: 25px;
}

.progress-bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(to right, #4facfe, #00c6ff);
}

/* QUESTION */
.question-box { display: none; }
.question-box.active { display: block; }

/* OPTIONS */
.option {
    display: block;
    padding: 12px;
    margin: 10px 0;
    border-radius: 10px;
    border: 1px solid #ddd;
    cursor: pointer;
    transition: 0.3s;
}

.option:hover {
    background: #f0f8ff;
}

body.dark .option:hover {
    background: #333;
}

/* BUTTONS */
.btn {
    padding: 12px 25px;
    border-radius: 25px;
    border: none;
    margin: 10px;
    cursor: pointer;
}

.next {
    background: #4facfe;
    color: white;
}

.prev {
    background: #aaa;
}

.submit {
    background: #00c6ff;
    color: white;
}

/* TOGGLE */
.toggle {
    position: absolute;
    top: 20px;
    right: 20px;
    cursor: pointer;
}
</style>

<div class="toggle" onclick="toggleDark()">🌙</div>

<div class="container">
    <h1>Mental Health Quiz 🧠</h1>

    <div class="progress">
        <div class="progress-bar" id="progressBar"></div>
    </div>

    <form action="/box/quiz" method="POST">

        <% questions.forEach((q, index) => { %>
            <div class="question-box <%= index === 0 ? 'active' : '' %>">

                <p>Question <%= index+1 %> / <%= questions.length %></p>
                <h3><%= q.text %></h3>

                <% q.options.forEach(opt => { %>
                    <label class="option">
                        <input type="radio" name="q<%= index %>" value="<%= opt.value %>" onchange="autoNext()">
                        <%= opt.text %>
                    </label>
                <% }) %>

                <div>
                    <button type="button" class="btn prev" onclick="prevQuestion()">Prev</button>
                    <button type="button" class="btn next" onclick="nextQuestion()">Next</button>
                </div>

            </div>
        <% }) %>

        <button type="submit" id="submitBtn" class="btn submit" style="display:none;">
            Submit 🚀
        </button>

    </form>
</div>

<script>
let current = 0;
const boxes = document.querySelectorAll(".question-box");
const total = boxes.length;
const progress = document.getElementById("progressBar");

function updateProgress() {
    progress.style.width = (current/total)*100 + "%";
}

function nextQuestion() {
    const selected = boxes[current].querySelector("input:checked");
    if (!selected) return alert("Select an option");

    boxes[current].classList.remove("active");
    current++;

    if (current < total) {
        boxes[current].classList.add("active");
    } else {
        document.getElementById("submitBtn").style.display = "block";
    }

    updateProgress();
}

function prevQuestion() {
    if (current === 0) return;

    boxes[current].classList.remove("active");
    current--;
    boxes[current].classList.add("active");

    updateProgress();
}

function autoNext() {
    setTimeout(() => nextQuestion(), 300);
}

function toggleDark() {
    document.body.classList.toggle("dark");
}

updateProgress();
</script>

<%- include("partials/footer") %>