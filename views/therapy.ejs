<%- include("partials/header") %>

    <style>
        body {
            margin: 0;
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #2b5876, #4e4376);
            color: white;
        }
        /* WRAPPER */
        
        .wrapper {
            max-width: 1100px;
            margin: auto;
            padding: 40px 20px;
        }
        /* TITLE */
        
        .title {
            text-align: center;
            margin-bottom: 30px;
        }
        
        .title h1 {
            font-size: 2.5rem;
            text-shadow: 0 0 20px rgba(0, 198, 255, 0.6);
        }
        /* GRID */
        
        .grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
        }
        /* CARD */
        
        .card {
            padding: 25px;
            border-radius: 20px;
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(20px);
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.3);
            transition: 0.3s;
        }
        
        .card:hover {
            transform: translateY(-5px);
        }
        /* SONG */
        
        .song {
            padding: 14px;
            margin: 10px 0;
            border-radius: 12px;
            cursor: pointer;
            background: rgba(255, 255, 255, 0.1);
            transition: 0.3s;
        }
        
        .song:hover {
            background: rgba(255, 255, 255, 0.25);
            transform: translateX(5px);
        }
        /* INPUT */
        
        input {
            width: 100%;
            padding: 12px;
            border-radius: 10px;
            border: none;
            margin-top: 10px;
        }
        
        input:focus {
            outline: none;
            box-shadow: 0 0 10px rgba(0, 198, 255, 0.7);
        }
        /* BUTTON */
        
        .btn {
            margin-top: 10px;
            padding: 10px 20px;
            border-radius: 20px;
            border: none;
            background: linear-gradient(90deg, #4facfe, #00c6ff);
            color: white;
            cursor: pointer;
        }
        /* CONTROLS */
        
        .controls {
            margin-top: 15px;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        
        .controls button {
            padding: 10px;
            border-radius: 50%;
            border: none;
            background: linear-gradient(90deg, #4facfe, #00c6ff);
            color: white;
            cursor: pointer;
            font-size: 16px;
        }
        
        .controls input {
            width: 120px;
        }
        /* RESPONSIVE */
        
        @media(max-width: 768px) {
            .grid {
                grid-template-columns: 1fr;
            }
        }
    </style>

    <div class="wrapper">

        <div class="title">
            <h1>🎧 Therapy Zone</h1>
            <p>Relax. Breathe. Let the music heal.</p>
        </div>

        <div class="grid">

            <!-- LOCAL MUSIC -->
            <div class="card">
                <h2>🌊 Our Calming Sounds</h2>

                <div class="song" onclick="playLocal('/audio/rain.mp3')">🌧 Rain</div>
                <div class="song" onclick="playLocal('/audio/calm.mp3')">🎶 Calm Piano</div>

                <audio id="localAudio"></audio>

                <div class="controls">
                    <button onclick="audio.play()">▶</button>
                    <button onclick="audio.pause()">⏸</button>
                </div>
            </div>

            <!-- YOUTUBE SEARCH -->
            <div class="card">
                <h2>🔍 Play Your Own</h2>

                <input id="songInput" placeholder="Search any song..." />
                <button class="btn" onclick="searchYT()">Play 🎧</button>

                <!-- hidden player -->
                <div id="player"></div>

                <!-- controls -->
                <div class="controls">
                    <button onclick="playVideo()">▶</button>
                    <button onclick="pauseVideo()">⏸</button>
                    <button onclick="stopVideo()">⏹</button>

                    <input type="range" min="0" max="100" value="50" onchange="setVolume(this.value)">
                </div>
            </div>

        </div>

    </div>

    <!-- YOUTUBE API -->
    <script src="https://www.youtube.com/iframe_api"></script>

    <script>
        let player;
        let audio = document.getElementById("localAudio");

        // YT INIT
        function onYouTubeIframeAPIReady() {
            player = new YT.Player('player', {
                height: '300',
                width: '400',
                videoId: '',
                playerVars: {
                    autoplay: 0
                }
            });
        }

        // LOCAL
        function playLocal(src) {
            audio.src = src;
            audio.play();

            if (player) player.stopVideo();
        }

        // SEARCH YT
        async function searchYT() {
            const query = document.getElementById("songInput").value;

            if (!query) return alert("Enter song");

            const res = await fetch(`/yt/search?q=${query}`);
            const data = await res.json();

            if (!data.videoId) {
                alert("No song found");
                return;
            }

            audio.pause();
            player.loadVideoById(data.videoId);
        }

        // CONTROLS
        function playVideo() {
            if (player) player.playVideo();
        }

        function pauseVideo() {
            if (player) player.pauseVideo();
        }

        function stopVideo() {
            if (player) player.stopVideo();
        }

        function setVolume(val) {
            if (player) player.setVolume(val);
        }
    </script>

    <%- include("partials/footer") %>