<%- include("partials/header") %>
<%- include("partials/navbar") %>

<style>
    html {
        scroll-behavior: smooth;
        font-family: 'Segoe UI', sans-serif;
    }

    .hero {
        text-align: center;
        padding: 100px 20px;
        background: linear-gradient(135deg, #4facfe, #00f2fe);
        color: white;
    }

    .hero h1 {
        font-size: 3rem;
        margin-bottom: 10px;
    }

    .hero p {
        font-size: 1.2rem;
        margin-bottom: 20px;
    }

    .hero .greeting-name {
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 6px;
        opacity: 0.92;
        letter-spacing: 0.3px;
    }

    .user-pill {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: rgba(255, 255, 255, 0.2);
        border: 1px solid rgba(255, 255, 255, 0.4);
        border-radius: 40px;
        padding: 8px 18px 8px 10px;
        margin-bottom: 24px;
        backdrop-filter: blur(6px);
    }

    .user-pill .avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.9);
        color: #4facfe;
        font-weight: 700;
        font-size: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .user-pill .pill-text {
        display: flex;
        flex-direction: column;
        text-align: left;
        line-height: 1.2;
    }

    .user-pill .pill-label {
        font-size: 11px;
        opacity: 0.75;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .user-pill .pill-name {
        font-size: 14px;
        font-weight: 600;
    }

    .btn {
        padding: 12px 25px;
        background: white;
        color: #333;
        border-radius: 25px;
        text-decoration: none;
        margin: 10px;
        display: inline-block;
        font-weight: bold;
        transition: 0.3s;
    }

    .btn:hover {
        background: #f1f1f1;
    }

    .section {
        padding: 80px 20px;
        text-align: center;
    }

    .card {
        width: 280px;
        height: 200px;
        padding: 25px;
        background: white;
        border-radius: 18px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
        transition: 0.3s;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
    }

    .card h2 {
        color: #3498db;
        font-size: 22px;
        font-weight: 600;
        margin-bottom: 10px;
        letter-spacing: 0.5px;
    }

    .card p {
        font-size: 15px;
        color: #555;
        line-height: 1.5;
        max-width: 220px;
    }

    .card:hover {
        transform: translateY(-10px) scale(1.02);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.12);
    }

    .features {
        display: flex;
        justify-content: center;
        gap: 25px;
        flex-wrap: wrap;
        align-items: stretch;
        background: #f7fbff;
    }

    .services {
        background: #eef7ff;
    }

    .services h1 {
        margin-bottom: 40px;
        font-size: 2.5rem;
        color: #2c3e50;
    }

    .services .card-container {
        display: flex;
        justify-content: center;
        gap: 25px;
        flex-wrap: wrap;
        align-items: stretch;
    }

    .about {
        background: #f4f6f9;
    }

    .helpline {
        background: #1e3c72;
        color: white;
    }

    .helpline p {
        font-size: 1.2rem;
    }

    a {
        text-decoration: none;
        color: inherit;
    }
</style>


<!-- HERO -->
<section class="hero">

    <% if (user) { %>
   <div class="user-pill">
    <div class="avatar"><%= user.fullName[0].toUpperCase() %></div>
    <div class="pill-text">
        <span class="pill-label">Logged in as</span>
        <span class="pill-name"><%= user.fullName %></span>
        <span class="pill-role"><%= user.role === 'admin' ? ' (Doctor)' : ' (User)' %></span>
    </div>
</div>
    <h1>Welcome to Breathify 🧠</h1>
    <% } else { %>
    <h1>Welcome to Breathify 🧠</h1>
    <% } %>

    <p>Your mental wellness companion</p>
    <a href="#services" class="btn">Explore Services</a>
    <a href="#about" class="btn">Learn More</a>
</section>


<!-- FEATURES -->
<section class="section features">
    <a href="/box/therapy">
        <div class="card">
            <h2>🧘 Therapy</h2>
            <p>Feeling overwhelmed? Lets slow things down together</p>
        </div>
    </a>

    <a href="/box/map">
        <div class="card">
            <h2>🩺 Nearby Health Centres</h2>
            <p>Tap to see hospitals near you</p>
        </div>
    </a>

    <a href="/chat/user_chat">
        <div class="card">
            <h2>💬 Chat Support</h2>
            <p>Talk to experts anytime</p>
        </div>
    </a>
</section>


<!-- SERVICES -->
<section id="services" class="section services">
    <h1>Our Services</h1>
    <div class="card-container">

        <a href="/box/quiz">
            <div class="card">
                <h2>📝 Quiz</h2>
                <p>Evaluate your mental state with smart quizzes</p>
            </div>
        </a>

        <a href="/box/bot">
            <div class="card">
                <h2>🤖 AI Companion</h2>
                <p>Chat with our intelligent chatbot anytime</p>
            </div>
        </a>

        <a href="/overcame/patient">
            <div class="card">
                <h2>🌟 Who Overcame</h2>
                <p>Connect with people who overcame struggles</p>
            </div>
        </a>

    </div>
</section>


<!-- ABOUT -->
<section id="about" class="section about">
    <h1>About Breathify</h1>
    <p>
        Breathify helps individuals improve mental well-being through AI tools, therapy, and community support.
        A safe space for healing and growth.
    </p>
</section>


<!-- HELPLINE -->
<section class="section helpline">
    <h1>Need Immediate Help? 🚨</h1>
    <p>📞 National Mental Health Helpline: 9152987821</p>
    <p>📞 Emergency: 112</p>
    <p>You are not alone. Help is always available.</p>
</section>


<%- include("partials/footer") %>